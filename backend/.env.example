# ─── Telegram ───────────────────────────────────────────
TELEGRAM_TOKEN=your_bot_token_here

# ─── Security ────────────────────────────────────────────
SECRET_KEY=change_this_to_a_random_string_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 дней

# ─── Database ────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./calorie_tracker.db

# ─── Ollama / AI ─────────────────────────────────────────
# true  = заглушка (дом, ноутбук)
# false = реальный Ollama (универский комп)
USE_MOCK_AI=true
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llava:7b

# ─── App ─────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# DeepSeek (запасной AI, если Ollama недоступен)
DEEPSEEK_API_KEY=your_deepseek_api_key
USE_DEEPSEEK_FALLBACK=false
